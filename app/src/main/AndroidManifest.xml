<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"
        android:maxSdkVersion="32" />

    <application
        android:name=".NetDebuggerApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.NetDebugger"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activity.ConnectionListActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".activity.PingActivity"
            android:exported="false" />
        <activity
            android:name=".activity.DnsQueryActivity"
            android:exported="false" />
        <activity
            android:name=".activity.PortScanActivity"
            android:exported="false" />
        <activity
            android:name=".activity.TracerouteActivity"
            android:exported="false" />
        <activity
            android:name=".activity.TcpClientActivity"
            android:exported="false" />
        <activity
            android:name=".activity.TcpServerActivity"
            android:exported="false" />
        <activity
            android:name=".activity.UdpClientActivity"
            android:exported="false" />
        <activity
            android:name=".activity.UdpServerActivity"
            android:exported="false" />
        <activity
            android:name=".activity.HttpCaptureActivity"
            android:exported="false" />
        <activity
            android:name=".activity.LanScanActivity"
            android:exported="false" />
        <activity
            android:name=".activity.IpLocationActivity"
            android:exported="false" />
        <activity
            android:name=".activity.WifiInfoActivity"
            android:exported="false" />

    </application>

</manifest>
